{
  "expo": {
    "name": "Remind Me Jo",
    "slug": "remind-me-jo",
    "version": "1.0.0",
    "scheme": "remindmejo",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C47FF"
      }
    },
    "ios": {
      "bundleIdentifier": "com.remindmejo.app",
      "supportsTablet": false
    }
  }
}
