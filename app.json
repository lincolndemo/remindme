{
  "expo": {
    "name": "Remind Me Jo",
    "slug": "remind-me-jo",
    "version": "1.0.0",
    "scheme": "remindmejo",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      ["expo-contacts", { "contactsPermission": "Allow Remind Me Jo to find contacts for your reminders." }],
      ["@react-native-voice/voice", {
        "microphonePermission": "Allow Remind Me Jo to use your microphone for voice reminders.",
        "speechRecognitionPermission": "Allow Remind Me Jo to recognise your speech."
      }],
      ["expo-notifications", {
        "icon": "./assets/notification-icon.png",
        "color": "#6C47FF",
        "sounds": []
      }]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C47FF"
      }
    },
    "ios": {
      "bundleIdentifier": "com.remindmejo.app",
      "supportsTablet": false
    },
    "extra": {
      "anthropicApiKey": "$EXPO_PUBLIC_ANTHROPIC_API_KEY"
    }
  }
}
